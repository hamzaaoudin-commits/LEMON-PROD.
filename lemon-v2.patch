+/* =========================================================================
+   v2 — lumière calmée, lecture confortable, scroll allégé
+   ========================================================================= */
+
+/* plus aucun halo néon sur le texte */
+.zest, .toc__n, .prob__authority, .proof__stat, .act__title,
+.hero h1, .display, .proto__link, h1, h2, h3, h4 { text-shadow:none; }
+.act__rule, .eyebrow::before, .progress { box-shadow:none; }
+.btn--primary:hover { box-shadow:0 10px 26px -16px rgba(0,0,0,.9); }
+.btn--ghost:hover { box-shadow:none; border-color:var(--gold-dim); }
+.proto__link:hover, .door:hover { text-shadow:none; }
+
+/* l'or ne sert plus qu'aux accents, pas aux blocs de texte */
+.lede, .faq__a, .toc__row p, .dcard p { color:var(--bone-2); }
+
+/* corps de texte : mesure et interlignage tenus */
+p { max-width:68ch; }
+.faq__a, .dcard p, .toc__row p { line-height:1.68; }
+
+/* rendu des polices sur fond sombre */
+body { -moz-osx-font-smoothing:grayscale; text-rendering:optimizeSpeed; }
+
+/* bas de page : mentions légales + langues */
+.foot__bottom { display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:1rem 1.6rem; }
+.foot__legal { display:inline-flex; align-items:center; gap:1.4rem; flex-wrap:wrap; }
+.foot__legal > a { font-family:var(--mono); font-size:.72rem; letter-spacing:.05em; color:var(--bone-3); transition:color .25s; }
+.foot__legal > a:hover { color:var(--gold-2); }
+.foot__legal .lang { font-size:.72rem; }
+
+/* renvoi vers l'index des métiers */
+.rooms-cta { text-align:left; }
+.rooms-cta .lede { margin-bottom:2.2rem; }
+
+/* scroll : on ne peint que ce qui est à l'écran */
+.section, .scene { content-visibility:auto; contain-intrinsic-size:auto 800px; }
+.hero, .nav, .foot { content-visibility:visible; }
+
+/* moins de couches composées en permanence */
+.immersive .hero { will-change:auto; }
+
+@media (prefers-reduced-motion:reduce){
+  *, *::before, *::after { animation-duration:.01ms !important; transition-duration:.01ms !important; scroll-behavior:auto !important; }
